# Copy this file to .env (or .env.local) and fill in real values.
# DO NOT commit .env files — they contain secrets.
# Firebase config files (google-services.json, GoogleService-Info.plist)
# are also gitignored — download from Firebase Console.

# Environment: dev | staging | prod
APP_ENV=dev

# Firebase project IDs (dev/staging/prod use different projects)
FIREBASE_PROJECT_ID_DEV=debt-payoff-dev
FIREBASE_PROJECT_ID_STAGING=debt-payoff-staging
FIREBASE_PROJECT_ID_PROD=debt-payoff-prod

# Feature flags (override defaults)
FEATURE_CLOUD_SYNC=true
FEATURE_PARTNER_SHARING=false
FEATURE_PREMIUM=false

# Analytics (can disable in dev)
ANALYTICS_ENABLED=false
CRASHLYTICS_ENABLED=false

# Build config
APP_DISPLAY_NAME=Debt Payoff (Dev)
